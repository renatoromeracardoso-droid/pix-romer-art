<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Relatório MEI</title>

<style>
body{font-family:Arial;padding:20px;background:#f8fafc;}
.box{background:white;padding:20px;border-radius:10px;}
h2{text-align:center;}

table{
  width:100%;
  border-collapse:collapse;
  margin-top:20px;
}

td{
  border:1px solid #000;
  padding:8px;
  font-size:14px;
}

.total{font-weight:bold;background:#eee;}

.btn{
  margin-top:20px;
  padding:10px;
  background:#22c55e;
  color:white;
  border:none;
  border-radius:8px;
  cursor:pointer;
}
</style>

</head>

<body>

<div class="box">

<h2>RELATÓRIO MENSAL DAS RECEITAS BRUTAS</h2>

<p><b>Empreendedor:</b> RomerArt</p>
<p><b>Período:</b> <span id="periodo"></span></p>

<table>

<tr><td>I - Revenda sem nota</td><td id="r1"></td></tr>
<tr><td>II - Revenda com nota</td><td id="r2"></td></tr>
<tr class="total"><td>III - Total comércio</td><td id="r3"></td></tr>

<tr><td>IV - Indústria sem nota</td><td>R$ 0,00</td></tr>
<tr><td>V - Indústria com nota</td><td>R$ 0,00</td></tr>
<tr class="total"><td>VI - Total indústria</td><td>R$ 0,00</td></tr>

<tr><td>VII - Serviços sem nota</td><td id="r7"></td></tr>
<tr><td>VIII - Serviços com nota</td><td id="r8"></td></tr>
<tr class="total"><td>IX - Total serviços</td><td id="r9"></td></tr>

<tr class="total"><td>X - TOTAL GERAL</td><td id="total"></td></tr>

</table>

<button class="btn" onclick="window.print()">🖨 Imprimir</button>

</div>

<script>

const API="https://script.google.com/macros/s/AKfycbzxPEsJg9iOwMIYey4ZyazDnhcgIHdV8rzE1aeF_y9Q78LHNHhlLyPUjy4nTTbegmC4zA/exec";

async function carregar(){

  const r=await fetch(API);
  const dados=await r.json();

  let revendaSem=0, revendaCom=0;
  let servSem=0, servCom=0;

  dados.forEach(p=>{

    const valor=parseFloat(p["Valor"])||0;
    const nota=(p["Status NF"]||"")=="emitido";
    const tipo=(p["Serviço"]||"").toLowerCase();

    const ehServico = tipo.includes("corte") || tipo.includes("laser");

    if(ehServico){
      if(nota) servCom+=valor;
      else servSem+=valor;
    }else{
      if(nota) revendaCom+=valor;
      else revendaSem+=valor;
    }

  });

  document.getElementById("r1").innerText="R$ "+revendaSem.toFixed(2);
  document.getElementById("r2").innerText="R$ "+revendaCom.toFixed(2);
  document.getElementById("r3").innerText="R$ "+(revendaSem+revendaCom).toFixed(2);

  document.getElementById("r7").innerText="R$ "+servSem.toFixed(2);
  document.getElementById("r8").innerText="R$ "+servCom.toFixed(2);
  document.getElementById("r9").innerText="R$ "+(servSem+servCom).toFixed(2);

  document.getElementById("total").innerText="R$ "+(
    revendaSem+revendaCom+servSem+servCom
  ).toFixed(2);

  document.getElementById("periodo").innerText=new Date().toLocaleDateString("pt-BR",{month:"long",year:"numeric"});

}

carregar();

</script>

</body>
</html>
